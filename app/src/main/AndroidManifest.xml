<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.gestaoepi">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GestaoEPI">

        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- outras activities -->
        <activity android:name=".MenuActivity" android:exported="false"/>
        <activity android:name=".SplashActivity" android:exported="false"/>
        <activity android:name=".MainActivity" android:exported="true"/>
        <activity android:name=".EntregasActivity" android:exported="false"/>
        <activity android:name=".EpisActivity" android:exported="false"/>
        <activity android:name=".FuncionariosActivity" android:exported="false"/>
        <activity android:name=".RelatoriosActivity" android:exported="false"/>
        <activity android:name=".ConfiguracoesActivity" android:exported="false"/>
        <activity android:name=".LogoutActivity" android:exported="false"/>
    </application>

</manifest>